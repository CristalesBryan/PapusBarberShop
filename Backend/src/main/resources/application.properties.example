# ===========================================
# CONFIGURACIÓN DEL SISTEMA PAPUS BARBERSHOP
# ===========================================
# Este es un archivo de ejemplo. Copia este archivo a application.properties
# y configura las variables de entorno necesarias.

# ==================== CONFIGURACIÓN DE BASE DE DATOS ====================
# Configuración de conexión a PostgreSQL
spring.datasource.url=jdbc:postgresql://localhost:5432/papus_barbershop
spring.datasource.username=postgres
spring.datasource.password=TU_CONTRASEÑA_AQUI
spring.datasource.driver-class-name=org.postgresql.Driver

# ==================== CONFIGURACIÓN JPA/HIBERNATE ====================
# Configuración de Hibernate para desarrollo
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.properties.hibernate.format_sql=true

# ==================== CONFIGURACIÓN DEL SERVIDOR ====================
# Puerto del servidor web
server.port=8080
# Ruta base de la aplicación
server.servlet.context-path=/

# ==================== CONFIGURACIÓN DE LOGGING ====================
# Niveles de logging para diferentes componentes
logging.level.com.papusbarbershop=DEBUG
logging.level.org.springframework.security=DEBUG
logging.level.org.hibernate.SQL=DEBUG
logging.level.org.hibernate.type.descriptor.sql.BasicBinder=TRACE

# ==================== CONFIGURACIÓN JWT ====================
# Clave secreta para firmar tokens JWT
jwt.secret=TU_CLAVE_SECRETA_JWT_AQUI
# Tiempo de expiración del token en milisegundos (24 horas)
jwt.expiration=86400000

# ==================== CONFIGURACIÓN DE VALIDACIÓN ====================
# Configuración de Jackson para serialización/deserialización JSON
spring.jackson.deserialization.fail-on-unknown-properties=false
spring.jackson.serialization.write-dates-as-timestamps=false

# ==================== CONFIGURACIÓN DE CORS ====================
# Configuración CORS para comunicación con frontend
cors.allowed-origins=http://localhost:3000,http://localhost:5173,http://localhost:4200
cors.allowed-methods=GET,POST,PUT,DELETE,OPTIONS
cors.allowed-headers=*
cors.allow-credentials=true

# ==================== CONFIGURACIÓN DE POOL DE CONEXIONES ====================
# Configuración del pool de conexiones HikariCP para optimización
spring.datasource.hikari.maximum-pool-size=20
spring.datasource.hikari.minimum-idle=5
spring.datasource.hikari.idle-timeout=300000
spring.datasource.hikari.pool-name=PapusBarberShopPool

# ==================== CONFIGURACIÓN DE EMAIL (Resend) ====================
# Resend para envío de correos (https://resend.com)
# - RESEND_API_KEY: API Key de Resend
# - RESEND_FROM_EMAIL: Remitente (ej: Citas Papus BarberShop <citas@papusbarbershop.com>)
# - RESEND_ADMIN_EMAIL: Email del admin para notificaciones de nuevas citas
resend.api-key=${RESEND_API_KEY:}
resend.from.email=${RESEND_FROM_EMAIL:Citas Papus BarberShop <citas@papusbarbershop.com>}
resend.admin.email=${RESEND_ADMIN_EMAIL:}

# ==================== CONFIGURACIÓN DE AMAZON S3 ====================
# Configuración de AWS S3 para almacenamiento de imágenes
# IMPORTANTE: Las credenciales AWS se obtienen de variables de entorno por seguridad
# Configura las variables de entorno AWS_ACCESS_KEY_ID y AWS_SECRET_ACCESS_KEY
# Puedes obtenerlas desde la consola de AWS IAM
aws.s3.region=us-east-2
aws.s3.bucket-name=papusbarbershop
aws.s3.access-key-id=${AWS_ACCESS_KEY_ID}
aws.s3.secret-access-key=${AWS_SECRET_ACCESS_KEY}
# Tiempo de expiración para URLs presignadas (en segundos, por defecto 1 hora)
aws.s3.presigned-url-expiration=3600

